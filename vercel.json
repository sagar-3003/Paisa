{
  "buildCommand": "cd scratch/paisa/frontend && npm run build",
  "outputDirectory": "scratch/paisa/frontend/dist",
  "installCommand": "cd scratch/paisa/frontend && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ],
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "0 3 * * *" }
  ]
}
